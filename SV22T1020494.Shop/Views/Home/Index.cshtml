@using SV22T1020494.Models.Catalog
@{
    ViewData["Title"] = "Tuấn Shop";
    var categories = ((ViewBag.Categories as IEnumerable<Category>) ?? new List<Category>()).ToList();
    var products = ((ViewBag.Products as IEnumerable<Product>) ?? new List<Product>()).ToList();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tuấn Shop - Mua sắm trực tuyến</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
            color: #2c3e50;
            line-height: 1.6;
        }

        a:hover {
            color: #5b7c99;
        }

        .product-card {
            background: white;
            border: 1px solid #e0e0e0;
            border-radius: 4px;
            overflow: hidden;
            transition: all 0.25s ease;
            cursor: pointer;
            display: flex;
            flex-direction: column;
        }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(44, 62, 80, 0.08);
        }

        /* main photo box: match style used in product detail main photo */
        .product-card .image {
            width: 100%;
            /* fixed height to make cards consistent and smaller */
            height: 200px;
            max-height: 220px;
            background: #fafafa;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            border-radius: 6px;
            border: 1px solid #eee;
        }

        .product-card .info {
            padding: 16px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .product-card .add-btn {
            width: 100%;
            padding: 8px;
            background: #5b7c99;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s;
        }

        .product-card .add-btn:hover {
            transform: translateY(-2px);
        }

        @@media (max-width: 1200px) {
            [style*="grid-template-columns: repeat(4"]  {
                grid-template-columns: repeat(3, 1fr) !important;
            }
        }

        @@media (max-width: 992px) {
            [style*="grid-template-columns: 200px"] {
                grid-template-columns: 150px 1fr !important;
            }
        }

        @@media (max-width: 768px) {
            [style*="grid-template-columns: 200px"] {
                grid-template-columns: 1fr !important;
            }

            [style*="grid-template-columns: repeat(4"] {
                grid-template-columns: repeat(2, 1fr) !important;
                gap: 12px !important;
            }

            [style*="flex: 1; display: flex"] {
                display: none !important;
            }
        }

        @@media (max-width: 480px) {
            [style*="grid-template-columns: repeat(2"] {
                grid-template-columns: 1fr !important;
            }

            [style*="grid-template-columns: repeat(4"] {
                grid-template-columns: 1fr !important;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    @await Html.PartialAsync("_Header")

    <div style="max-width: 1280px; margin: 0 auto; padding: 24px 16px; display: grid; grid-template-columns: 200px 1fr; gap: 24px;">
        <!-- Sidebar (categories only) -->
        <div style="align-self:start; margin-top:0; padding-right:20px;">
            <aside style="background:white;border:1px solid #e0e0e0;border-radius:8px;padding:16px;">
                @await Html.PartialAsync("_SideBar")
            </aside>
        </div>

        <!-- MAIN CONTENT -->
        <main>
            <div style="background:white;border:1px solid #e0e0e0;border-radius:8px;padding:16px;">
                <!-- PRODUCTS GRID -->
                <div style="display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 16px;">
                @{
                    // products variable declared at top of file; reuse it here
                    // var products = (ViewBag.Products as IEnumerable<SV22T1020494.Models.Catalog.Product>) ?? new List<SV22T1020494.Models.Catalog.Product>();
                    if (products.Any())
                    {
                        int index = 0;
                        foreach (var product in products)
                        {
                            var discount = (int)((product.Price > 0) ? Math.Round(((1890000 - product.Price) / 1890000) * 100) : 0);
                            <div class="product-card" data-product-id="@product.ProductID" onclick="navigateToDetail(@product.ProductID)">
                                <div class="image">
                                    @if (!string.IsNullOrWhiteSpace(product.Photo))
                                    {
                                        <img src="@Url.Content("~/images/products/" + product.Photo)" alt="@product.ProductName" style="width:100%; height:100%; object-fit:cover; display:block;" />
                                    }
                                    else
                                    {
                                        <svg style="width:60%; height:60%;" viewBox="0 0 100 100" fill="none">
                                            <rect x="20" y="20" width="60" height="60" fill="#ddd" rx="4" />
                                            <circle cx="50" cy="45" r="8" fill="#999" />
                                            <path d="M 30 65 L 35 50 L 45 55 L 55 40 L 70 65" stroke="#999" stroke-width="2" fill="none" />
                                        </svg>
                                    }

                                    @* Badges removed: no 'New' or sale percentage shown *@

                                    <div style="position:absolute; top:12px; right:12px; width:32px; height:32px; background:rgba(255,255,255,0.95); border:1px solid #e0e0e0; border-radius:50%; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.2s; font-size:16px;" onclick="event.stopPropagation(); addToWishlist(event, '@product.ProductID')">♡</div>
                                </div>

                                <div class="info">
                                    <h3 style="font-size:13px; font-weight:600; color:#2c3e50; margin-bottom:8px; min-height:32px; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                                        @(product.ProductName.Length > 35 ? product.ProductName.Substring(0, 35) + "..." : product.ProductName)
                                    </h3>

                                    <div style="display:flex; align-items:center; gap:6px; margin-bottom:8px; font-size:12px;">
                                        <span style="color:#ff6b6b; letter-spacing:-2px;">★★★★★</span>
                                        <span style="color:#7f8c8d;">(@(index + 1) reviews)</span>
                                    </div>

                                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
                                        <span style="font-size:16px; font-weight:700; color:#2c3e50;">₫@product.Price.ToString("N0")</span>
                                        @* sale percentage removed *@
                                    </div>

                                    @* Add to cart removed on home page per requirements *@
                                </div>
                            </div>
                            index++;
                        }
                    }
                    else
                    {
                        <p style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #7f8c8d;">
                            No products available
                        </p>
                    }
                }
                </div>
            </div>

            <!-- Server-side pagination -->
            @{
                var total = (ViewBag.TotalProducts as int?) ?? 0;
                var current = (ViewBag.CurrentPage as int?) ?? 1;
                var pageSize = (ViewBag.PageSize as int?) ?? 12;
                var totalPages = (int)Math.Ceiling(total / (double)pageSize);
            }
            @if(totalPages > 1)
            {
                var prevPage = Math.Max(1, current - 1);
                var nextPage = Math.Min(totalPages, current + 1);
                <div style="display:flex; justify-content:center; gap:8px; margin-top:20px; align-items:center;">
                    <a class="add-btn" style="background:#fff;color:#5b7c99;border:1px solid #e0e0e0; padding:6px 10px; text-decoration:none;" href="@Url.Action("Index","Home", new { page = prevPage })" onclick="window.location.href='@Url.Action("Index","Home", new { page = prevPage })'; return false;">‹</a>
                    @{
                        // compressed pager: show first, nearby pages, last with ellipses
                        int window = 2; // pages on each side of current
                        int start = Math.Max(1, current - window);
                        int end = Math.Min(totalPages, current + window);

                        if (start > 1)
                        {
                            <a class="add-btn" style="background:@(1==current?"#5b7c99":"#fff");color:@(1==current?"#fff":"#5b7c99");padding:6px 10px;text-decoration:none;border:1px solid #e0e0e0;" href="@Url.Action("Index","Home", new { page = 1 })">1</a>
                            if (start > 2)
                            {
                                <span style="padding:6px 4px;color:#7f8c8d;">...</span>
                            }
                        }

                        for (int i = start; i <= end; i++)
                        {
                            var clsStyle = i == current ? "background:#5b7c99;color:#fff;" : "background:#fff;color:#5b7c99;";
                            <a class="add-btn" style="@clsStyle padding:6px 10px; text-decoration:none; border:1px solid #e0e0e0;" href="@Url.Action("Index","Home", new { page = i })" onclick="window.location.href='@Url.Action("Index","Home", new { page = i })'; return false;">@i</a>
                        }

                        if (end < totalPages)
                        {
                            if (end < totalPages - 1)
                            {
                                <span style="padding:6px 4px;color:#7f8c8d;">...</span>
                            }
                            <a class="add-btn" style="background:@(totalPages==current?"#5b7c99":"#fff");color:@(totalPages==current?"#fff":"#5b7c99");padding:6px 10px;text-decoration:none;border:1px solid #e0e0e0;" href="@Url.Action("Index","Home", new { page = totalPages })" onclick="window.location.href='@Url.Action("Index","Home", new { page = totalPages })'; return false;">@totalPages</a>
                        }
                    }
                    <a class="add-btn" style="background:#fff;color:#5b7c99;border:1px solid #e0e0e0; padding:6px 10px; text-decoration:none;" href="@Url.Action("Index","Home", new { page = Math.Min(totalPages, current+1) })" onclick="window.location.href='@Url.Action("Index","Home", new { page = Math.Min(totalPages, current+1) })'; return false;">›</a>
                </div>
            }
        </main>
    </div>

    <!-- Footer -->
    @await Html.PartialAsync("_Footer")

    <script>
        // keep wishlist local logic
        let wishlistItems = JSON.parse(localStorage.getItem('wishlist')) || [];
        function addToWishlist(e, productId) {
            const element = e.currentTarget || e.target;
            if (!wishlistItems.includes(productId)) {
                wishlistItems.push(productId);
                element.style.color = '#ff6b6b';
            } else {
                wishlistItems = wishlistItems.filter(id => id !== productId);
                element.style.color = '#2c3e50';
            }
            localStorage.setItem('wishlist', JSON.stringify(wishlistItems));
            window.updateBadges && window.updateBadges();
        }

        function navigateToDetail(id){
            window.location.href = '/Products/Detail/' + id;
        }
    </script>
    <!-- client-side pagination removed: using server-side paging -->
</body>
</html>
