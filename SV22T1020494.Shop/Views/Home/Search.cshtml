@using SV22T1020494.Models.Catalog
@{
    ViewData["Title"] = "Kết quả tìm kiếm";
    var query = (ViewBag.Query as string) ?? Context.Request.Query["q"].ToString();
    var products = ((ViewBag.Products as IEnumerable<Product>) ?? new List<Product>()).ToList();
    var sort = (ViewBag.Sort as string) ?? Context.Request.Query["sort"].ToString();
    var selectedCategories = Context.Request.Query["categories"];
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kết quả tìm kiếm - Tuấn Shop</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; color: #2c3e50; }
        .product-card { display:block; background:white; border:1px solid #e0e0e0; border-radius:4px; overflow:hidden; transition: all 0.25s ease; color:inherit; text-decoration:none; }
        .product-card:hover { transform: translateY(-6px); box-shadow: 0 12px 30px rgba(44,62,80,0.08); }
        .product-card .image { border-radius:6px; }
        select.sort-select:hover { box-shadow: 0 4px 14px rgba(91,124,153,0.08); border-color:#bcd; }
        .category-label:hover, .supplier-label:hover { background:#f6fbff; border-radius:6px; color:#2c3e50; transform: translateX(6px); }
    </style>
</head>
<body>
    @await Html.PartialAsync("_Header")

    <div style="max-width: 1400px; margin: 0 auto; padding: 32px 24px; display: grid; grid-template-columns: 200px 1fr; gap: 32px;">
        <div style="align-self:start;">
            <aside style="background:white;border:1px solid #e0e0e0;border-radius:8px;padding:16px;">
                @await Html.PartialAsync("_SideBar")
            </aside>
        </div>

        <main>
            <div style="background:white;border:1px solid #e0e0e0;border-radius:8px;padding:16px;">
            <div style="margin-bottom:18px;">
                @{ var totalResults = (ViewBag.TotalProducts as int?) ?? products.Count; }
                @if (!string.IsNullOrWhiteSpace(query))
                {
                    <div style="font-size:14px; color:#7f8c8d;">Có <strong>@totalResults</strong> kết quả tìm kiếm cho "<strong>@query</strong>"</div>
                }
                else
                {
                    <div style="font-size:14px; color:#7f8c8d;">Có <strong>@totalResults</strong> kết quả</div>
                }
            </div>

            <div style="display:flex; align-items:center; gap:12px; margin-bottom: 16px;">
                <div style="font-weight:600; color:#2c3e50;">Tìm kiếm theo</div>
                <form id="sortForm" method="get" action="~/Home/Search" style="display:flex; gap:8px; align-items:center;">
                    <input type="hidden" name="q" value="@query" />
                    @* Preserve selected categories when changing sort *@
                    @if (selectedCategories.Any())
                    {
                        foreach (var c in selectedCategories)
                        {
                            <input type="hidden" name="categories" value="@c" />
                        }
                    }
                    <select name="sort" class="sort-select" onchange="document.getElementById('sortForm').submit()" style="padding:8px 12px; border-radius:4px; border:1px solid #e0e0e0; background:white;">
                        <option value="" selected="@(string.IsNullOrWhiteSpace(sort) ? "selected" : null)">Mặc định</option>
                        <option value="price_desc" selected="@(sort == "price_desc" ? "selected" : null)">Giá: Cao đến Thấp</option>
                        <option value="price_asc" selected="@(sort == "price_asc" ? "selected" : null)">Giá: Thấp đến Cao</option>
                    </select>
                </form>
            </div>

                <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;">
                @{
                    if (products.Any())
                    {
                        int index = 0;
                        foreach (var product in products)
                        {
                            var discount = (int)((product.Price > 0) ? Math.Round(((1890000 - product.Price) / 1890000) * 100) : 0);

                            <a class="product-card" href="@Url.Action("Detail","Products", new { id = product.ProductID })" data-product-id="@product.ProductID">
                                <div class="image" style="width:100%; aspect-ratio:1; background: linear-gradient(135deg, #f0f0f0 0%, #e8e8e8 100%); display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden;">
                                    @if (!string.IsNullOrWhiteSpace(product.Photo))
                                    {
                                        <img src="@Url.Content("~/images/products/" + product.Photo)" alt="@product.ProductName" style="width:100%; height:100%; object-fit:cover; display:block;" />
                                    }
                                    else
                                    {
                                        <svg style="width: 60%; height: 60%;" viewBox="0 0 100 100" fill="none">
                                            <rect x="20" y="20" width="60" height="60" fill="#ddd" rx="4" />
                                            <circle cx="50" cy="45" r="8" fill="#999" />
                                            <path d="M 30 65 L 35 50 L 45 55 L 55 40 L 70 65" stroke="#999" stroke-width="2" fill="none" />
                                        </svg>
                                    }
                                    @* Badges (New / discount) removed on Search page *@

                                    <div style="position: absolute; top: 12px; right: 12px; width: 32px; height: 32px; background: rgba(255,255,255,0.95); border: 1px solid #e0e0e0; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; font-size: 16px;" onclick="event.stopPropagation(); addToWishlist(event, '@product.ProductID')">♡</div>
                                </div>

                                <div style="padding: 16px;">
                                    <h3 style="font-size: 13px; font-weight: 600; color: #2c3e50; margin-bottom: 8px; min-height: 32px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @(product.ProductName.Length > 35 ? product.ProductName.Substring(0, 35) + "..." : product.ProductName)
                                    </h3>

                                    <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 8px; font-size: 12px;">
                                        <span style="color: #ff6b6b; letter-spacing: -2px;">★★★★★</span>
                                        <span style="color: #7f8c8d;">(@(index + 1) reviews)</span>
                                    </div>

                                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px;">
                                        <span style="font-size: 16px; font-weight: 700; color: #2c3e50;">₫@product.Price.ToString("N0")</span>
                                        @* discount badge removed *@
                                    </div>

                                </div>
                            </a>
                            index++;
                        }
                    }
                    else
                    {
                        <p style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #7f8c8d;">Không có kết quả</p>
                    }
                }
                </div>
            </div>

            <!-- Server-side pagination -->
            @{
                var total = (ViewBag.TotalProducts as int?) ?? 0;
                var current = (ViewBag.CurrentPage as int?) ?? 1;
                var pageSize = (ViewBag.PageSize as int?) ?? 12;
                var totalPages = (int)Math.Ceiling(total / (double)pageSize);
                var qVal = ViewBag.Query as string ?? string.Empty;
                var sortVal = ViewBag.Sort as string ?? string.Empty;
                var selectedCat = (ViewBag.SelectedCategories as int[])?.FirstOrDefault() ?? 0;
                var selectedSupplier = (ViewBag.SelectedSupplier as int?) ?? 0;
            }
            @if(totalPages > 1)
            {
                var prevPage = Math.Max(1, current - 1);
                var nextPage = Math.Min(totalPages, current + 1);
                <div style="display:flex; justify-content:center; gap:8px; margin-top:20px; align-items:center;">
                    <a class="add-btn" style="background:#fff;color:#5b7c99;border:1px solid #e0e0e0; padding:6px 10px; text-decoration:none;" href="@Url.Action("Search","Home", new { q = qVal, sort = sortVal, categories = selectedCat == 0 ? (int?)null : selectedCat, supplier = selectedSupplier == 0 ? (int?)null : selectedSupplier, page = prevPage })" onclick="window.location.href='@Url.Action("Search","Home", new { q = qVal, sort = sortVal, categories = selectedCat == 0 ? (int?)null : selectedCat, supplier = selectedSupplier == 0 ? (int?)null : selectedSupplier, page = prevPage })'; return false;">‹</a>
                    @{
                        int window = 2; // pages on each side of current
                        int start = Math.Max(1, current - window);
                        int end = Math.Min(totalPages, current + window);

                        if (start > 1)
                        {
                            <a class="add-btn" style="background:@(1==current?"#5b7c99":"#fff");color:@(1==current?"#fff":"#5b7c99");padding:6px 10px;text-decoration:none;border:1px solid #e0e0e0;" href="@Url.Action("Search","Home", new { q = qVal, sort = sortVal, categories = selectedCat == 0 ? (int?)null : selectedCat, supplier = selectedSupplier == 0 ? (int?)null : selectedSupplier, page = 1 })">1</a>
                            if (start > 2)
                            {
                                <span style="padding:6px 4px;color:#7f8c8d;">...</span>
                            }
                        }

                        for (int i = start; i <= end; i++)
                        {
                            var clsStyle = i == current ? "background:#5b7c99;color:#fff;" : "background:#fff;color:#5b7c99;";
                            <a class="add-btn" style="@clsStyle padding:6px 10px; text-decoration:none; border:1px solid #e0e0e0;" href="@Url.Action("Search","Home", new { q = qVal, sort = sortVal, categories = selectedCat == 0 ? (int?)null : selectedCat, supplier = selectedSupplier == 0 ? (int?)null : selectedSupplier, page = i })" onclick="window.location.href='@Url.Action("Search","Home", new { q = qVal, sort = sortVal, categories = selectedCat == 0 ? (int?)null : selectedCat, supplier = selectedSupplier == 0 ? (int?)null : selectedSupplier, page = i })'; return false;">@i</a>
                        }

                        if (end < totalPages)
                        {
                            if (end < totalPages - 1)
                            {
                                <span style="padding:6px 4px;color:#7f8c8d;">...</span>
                            }
                            <a class="add-btn" style="background:@(totalPages==current?"#5b7c99":"#fff");color:@(totalPages==current?"#fff":"#5b7c99");padding:6px 10px;text-decoration:none;border:1px solid #e0e0e0;" href="@Url.Action("Search","Home", new { q = qVal, sort = sortVal, categories = selectedCat == 0 ? (int?)null : selectedCat, supplier = selectedSupplier == 0 ? (int?)null : selectedSupplier, page = totalPages })" onclick="window.location.href='@Url.Action("Search","Home", new { q = qVal, sort = sortVal, categories = selectedCat == 0 ? (int?)null : selectedCat, supplier = selectedSupplier == 0 ? (int?)null : selectedSupplier, page = totalPages })'; return false;">@totalPages</a>
                        }
                    }
                    <a class="add-btn" style="background:#fff;color:#5b7c99;border:1px solid #e0e0e0; padding:6px 10px; text-decoration:none;" href="@Url.Action("Search","Home", new { q = qVal, sort = sortVal, categories = selectedCat == 0 ? (int?)null : selectedCat, supplier = selectedSupplier == 0 ? (int?)null : selectedSupplier, page = Math.Min(totalPages, current+1) })" onclick="window.location.href='@Url.Action("Search","Home", new { q = qVal, sort = sortVal, categories = selectedCat == 0 ? (int?)null : selectedCat, supplier = selectedSupplier == 0 ? (int?)null : selectedSupplier, page = Math.Min(totalPages, current+1) })'; return false;">›</a>
                </div>
            }
        </main>
    </div>
    </div>

    @await Html.PartialAsync("_Footer")

    <script>
        let cartItems = JSON.parse(localStorage.getItem('cart')) || [];
        let wishlistItems = JSON.parse(localStorage.getItem('wishlist')) || [];
        function updateBadges() {
            const cartEl = document.getElementById('cartCount');
            const wishEl = document.getElementById('wishlistCount');
            if (cartEl) cartEl.textContent = cartItems.length;
            if (wishEl) wishEl.textContent = wishlistItems.length;
        }
        function addToCart(productId) {
            if (!cartItems.includes(productId)) {
                cartItems.push(productId);
                localStorage.setItem('cart', JSON.stringify(cartItems));
                updateBadges();
                alert('Product added to cart!');
            } else {
                alert('Product already in cart!');
            }
        }
        function addToWishlist(e, productId) {
            const element = e.currentTarget || e.target;
            if (!wishlistItems.includes(productId)) {
                wishlistItems.push(productId);
                element.style.color = '#ff6b6b';
            } else {
                wishlistItems = wishlistItems.filter(id => id !== productId);
                element.style.color = '#2c3e50';
            }
            localStorage.setItem('wishlist', JSON.stringify(wishlistItems));
            updateBadges();
        }
        updateBadges();
    </script>
</body>
</html>