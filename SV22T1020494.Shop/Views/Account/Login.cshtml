@model SV22T1020494.Shop.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div style="max-width:420px;margin:48px auto;background:white;padding:24px;border-radius:6px;border:1px solid #e0e0e0;">
    <h2 style="text-align:center;margin-bottom:18px;color:#2c3e50;">Đăng nhập</h2>

    @{
        var genericError = ViewData.ModelState[string.Empty]?.Errors.FirstOrDefault()?.ErrorMessage;
    }

    @if (!string.IsNullOrEmpty(genericError))
    {
        <div style="color:#e74c3c;margin-bottom:12px;font-weight:600;">@genericError</div>
    }

    <form method="post" asp-action="Login">
        @Html.HiddenFor(m => m.ReturnUrl)
        <div style="display:flex;flex-direction:column;gap:12px;">
            <div>
                <label style="display:block;margin-bottom:6px;color:#2c3e50;">Email <span style="color:#e74c3c;font-weight:700;">*</span></label>
                <input asp-for="Email" type="email" placeholder="Nhập email" class="form-control" style="width:100%;padding:10px;border:1px solid #e6ecf0;border-radius:4px;background:#fafafa;" />
            </div>

            <div>
                <label style="display:block;margin-bottom:6px;color:#2c3e50;">Mật khẩu <span style="color:#e74c3c;font-weight:700;">*</span></label>
                <input asp-for="Password" type="password" class="form-control" style="width:100%;padding:10px;border:1px solid #e6ecf0;border-radius:4px;background:#fafafa;" />
            </div>

            <div>
                <button type="submit" class="btn" style="width:100%;padding:12px;background:#5b7c99;border:none;border-radius:4px;color:white;font-weight:600;">Đăng nhập</button>
            </div>

            <div style="text-align:center;color:#5b7c99;">
                <a href="/Account/Register" style="color:#5b7c99;text-decoration:none;">Chưa có tài khoản? Đăng ký</a>
            </div>
        </div>
    </form>
</div>