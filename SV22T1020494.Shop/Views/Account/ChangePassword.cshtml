@model SV22T1020494.Shop.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

@await Html.PartialAsync("_Header")

@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString()?.ToLowerInvariant() ?? "";
    string linkStyle(string act) => "color:#5b7c99;text-decoration:none;" + (currentAction == act ? "font-weight:700;" : "");
    string linkClass(string act) => "account-link" + (currentAction == act ? " active" : "");
}

<div style="max-width:1280px;margin:24px auto;padding:16px;display:grid;grid-template-columns:260px 650px;gap:24px;align-items:start;justify-content:start;">
    <aside class="account-sidebar" style="background:#fff;padding:16px;border:1px solid #e0e0e0;border-radius:6px;align-self:start;min-width:260px;">
        <h3 style="font-size:16px;margin-bottom:12px;color:#2c3e50;">Quản lý tài khoản</h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;">
            <li><a href="@Url.Action("AccountInfo","Account")" class='@linkClass("accountinfo")' style="@linkStyle("accountinfo")">Thông tin tài khoản</a></li>
            <li><a href="@Url.Action("Order","Account")" class='@linkClass("order")' style="@linkStyle("order")">Xem đơn hàng</a></li>
            <li><a href="@Url.Action("ChangePassword","Account")" class='@linkClass("changepassword")' style="@linkStyle("changepassword")">Đổi mật khẩu</a></li>
        </ul>
    </aside>

    <section style="background:#fff;padding:16px;border:1px solid #e0e0e0;border-radius:6px;align-self:start;width:100%;">
        <h3 style="margin-top:0;color:#2c3e50;font-size:28px;">Đổi mật khẩu</h3>
        @if (TempData["ChangePwdMsg"] != null)
        {
            <div style="color:#2e7d32;margin-bottom:12px;font-weight:600;">@TempData["ChangePwdMsg"]</div>
        }

        <form method="post" asp-action="ChangePassword">
            <div style="display:flex;flex-direction:column;gap:18px;width:100%;max-width:720px;margin:0;padding-top:8px;">
                <div>
                    <label style="display:block;margin-bottom:8px;color:#2c3e50;font-size:16px;">Mật khẩu cũ</label>
                    <input asp-for="OldPassword" type="password" class="form-control" style="width:100%;padding:12px;border:1px solid #e6ecf0;border-radius:4px;background:#fafafa;" />
                </div>
                <div>
                    <label style="display:block;margin-bottom:8px;color:#2c3e50;font-size:16px;">Mật khẩu mới</label>
                    <input id="newPwd" asp-for="NewPassword" type="password" class="form-control" style="width:100%;padding:12px;border:1px solid #e6ecf0;border-radius:4px;background:#fafafa;" />
                </div>
                <div>
                    <label style="display:block;margin-bottom:8px;color:#2c3e50;font-size:16px;">Xác nhận mật khẩu mới</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" style="width:100%;padding:12px;border:1px solid #e6ecf0;border-radius:4px;background:#fafafa;" />
                </div>
                <div style="display:flex;gap:12px;">
                    <button type="submit" class="btn-account" style="width:100%;padding:12px;background:#5b7c99;border:none;border-radius:4px;color:white;font-weight:600;">Đổi mật khẩu</button>
                </div>
            </div>
        </form>
    </section>
</div>

@await Html.PartialAsync("_Footer")

<style>
    .btn-account{transition:all .15s ease}
    .btn-account:hover{transform:translateY(-3px);box-shadow:0 8px 20px rgba(44,62,80,0.06)}
    /* Sidebar hover/active indicator */
    .account-sidebar { position:relative; }
    .account-sidebar .account-link { display:block; padding:6px 8px 6px 12px; position:relative; color:inherit; transition:color .12s ease; }
    .account-sidebar .account-link::before { content:""; position:absolute; left:0; top:8px; bottom:8px; width:4px; background:transparent; border-radius:2px; transition:background .12s ease, transform .12s ease; transform:scaleY(0); transform-origin:center; }
    .account-sidebar .account-link:hover::before { background:#5b7c99; transform:scaleY(1); }
    .account-sidebar .account-link.active::before { background:#5b7c99; transform:scaleY(1); }
    .account-sidebar .account-link.active { font-weight:700; color:#2c3e50; }
</style>
<script>
    // basic client-side check
    document.querySelector('form[asp-action="ChangePassword"]').addEventListener('submit', function(e){
        var oldP = this.oldPassword.value.trim();
        var newP = this.newPassword.value.trim();
        var conf = this.confirmPassword.value.trim();
        if (!oldP || !newP || !conf) {
            e.preventDefault();
            alert('Vui lòng điền đầy đủ thông tin.');
            return false;
        }
        if (newP !== conf) {
            e.preventDefault();
            alert('Mật khẩu mới và xác nhận không khớp.');
            return false;
        }
    });
</script>
