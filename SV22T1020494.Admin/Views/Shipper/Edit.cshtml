@model SV22T1020494.Models.ShipperViewModel
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Shipper" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bicycle me-2"></i>
                    Thông tin người giao hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="~/Shipper/Save">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ShipperID" />

                    <div class="mb-3">
                        <label class="form-label">Tên người giao hàng</label>
                        <input asp-for="ShipperName" type="text" class="form-control" placeholder="Nhập tên người giao hàng" autofocus />
                        <span asp-validation-for="ShipperName" class="text-danger"></span>
                        <div class="form-text text-muted">Vui lòng nhập tên người giao hàng</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Điện thoại</label>
                        <input asp-for="Phone" type="tel" class="form-control" placeholder="Nhập số điện thoại" />
                        <div class="form-text text-muted">Vui lòng nhập số điện thoại</div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
