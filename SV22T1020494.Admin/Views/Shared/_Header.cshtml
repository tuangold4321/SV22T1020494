<nav class="app-header navbar navbar-expand bg-body-secondary">
    <div class="container-fluid">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                    <i class="bi bi-list"></i>
                </a>
            </li>
            <li class="nav-item d-none d-md-block"><a href="~/" class="nav-link">Trang chủ</a></li>            
        </ul>        
        <ul class="navbar-nav ms-auto">
            @{
                var isAuth = User?.Identity?.IsAuthenticated ?? false;
                var UserData = isAuth ? User.GetUserData() : null;
                var avatarPath = (isAuth && !string.IsNullOrWhiteSpace(UserData?.Photo))
                    ? Url.Content($"~/images/employees/{UserData.Photo}")
                    : Url.Content("~/lib/adminlte/assets/img/user2-160x160.jpg");
            }
            @if (!isAuth)
            {
                <li class="nav-item">
                    <a href="~/Account/Login" class="nav-link action-indicator" style="display:inline-flex; align-items:center; gap:6px; padding:6px 10px;">
                        <span class="fw-semibold">Đăng nhập</span>
                    </a>
                </li>
            }
            else
            {
                <li class="nav-item dropdown user-menu">
                    <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                        <img src="@avatarPath" class="user-image rounded-circle shadow" alt="User Image" />
                        <span class="d-none d-md-inline">@UserData?.DisplayName</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">                    
                        <li class="user-header text-bg-primary">
                            <img src="@avatarPath" class="rounded-circle shadow" alt="User Image" />
                            <p>
                                @UserData?.DisplayName
                            </p>
                        </li>                    
                        <li class="user-footer">
                            <a href="~/Account/ChangePassword" class="btn btn-default btn-flat">Đổi mật khẩu</a>
                            <a href="~/Account/Logout" class="btn btn-default btn-flat float-end">Thoát</a>
                        </li>                    
                    </ul>
                </li>
            }
        </ul>
        
        <style>
            .action-indicator { position: relative; }
            .action-indicator::after { content: ""; position: absolute; left: 0; right: 0; bottom: -6px; height: 3px; background: transparent; transform: scaleX(0); transform-origin: left; transition: transform .15s ease, background .15s ease; border-radius:2px; }
            .action-indicator:hover::after { background:#0d6efd; transform: scaleX(1); }
        </style>
    </div>
</nav>