@model SV22T1020494.Models.Common.PagedResult<SV22T1020494.Models.HR.Employee>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> nhân viên
</div>

<div class="card">
    <div class="card-body p-1">
        <div class="table-responsive">
            <table class="table table-bordered table-hover mb-0 align-middle">
                <thead class="table-secondary">
                    <tr>
                        <th>Họ và tên</th>
                        <th style="width:120px;">Ngày sinh</th>
                        <th style="width:140px;">Điện thoại</th>
                        <th style="width:200px;">Email</th>
                        <th>Địa chỉ</th>
                        <th class="text-center" style="width:140px;">Trạng thái</th>
                        <th class="text-center" style="width:100px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var items = Model.DataItems ?? Enumerable.Empty<SV22T1020494.Models.HR.Employee>();
                        var list = items.OrderBy(e => e.EmployeeID).ToList();
                    }
                    @if (list.Any())
                    {
                        foreach (var item in list)
                        {
                            <tr>
                                <td>@item.FullName</td>
                                <td>@(item.BirthDate?.ToString("yyyy-MM-dd") ?? "")</td>
                                <td>@item.Phone</td>
                                <td>@item.Email</td>
                                <td>@item.Address</td>
                                <td class="text-center">
                                    @if (item.IsWorking == true)
                                    {
                                        <span class="badge bg-success">Đang làm việc</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Ngưng</span>
                                    }
                                </td>
                                <td class="text-center text-nowrap">
                                    <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-sm btn-primary" title="Cập nhật">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-sm btn-danger" title="Xóa" style="margin:0 4px;">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                    <a href="~/Employee/ChangePassword/@item.EmployeeID" class="btn btn-sm btn-warning ms-2" title="Đổi mật khẩu">
                                        <i class="bi bi-key"></i>
                                    </a>
                                    <a href="~/Employee/ChangeRole/@item.EmployeeID" class="btn btn-sm btn-info ms-1" title="Cấp quyền">
                                        <i class="bi bi-shield-check"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center">Không có dữ liệu</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer">
        <ul class="pagination justify-content-center">
            @foreach (var p in Model.GetDisplayPages())
            {
                if (p.IsCurrent)
                {
                    <li class="page-item active"><a class="page-link">@p.Page</a></li>
                }
                else if (p.IsEllipsis)
                {
                    <li class="page-item"><a class="page-link">...</a></li>
                }
                else
                {
                    <li class="page-item ">
                        <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">@p.Page</a>
                    </li>
                }
            }
        </ul>
    </div>
</div>