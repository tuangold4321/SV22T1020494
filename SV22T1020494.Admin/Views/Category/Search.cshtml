@model SV22T1020494.Models.Common.PagedResult<SV22T1020494.Models.Catalog.Category>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> loại hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên loại hàng</th>
                    <th>Mô tả</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems != null && Model.DataItems.Any())
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td>@item.CategoryName</td>
                            <td>@item.Description</td>
                            <td class="text-center text-nowrap">
                                <a href="~/Category/Edit/@item.CategoryID" class="btn btn-sm btn-primary" title="Sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Category/Delete/@item.CategoryID" class="btn btn-sm btn-danger" title="Xóa" style="margin:0 4px;">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <ul class="pagination justify-content-center">
            @foreach (var p in Model.GetDisplayPages())
            {
                if (p.IsCurrent)
                {
                    <li class="page-item active"><a class="page-link">@p.Page</a></li>
                }
                else if (p.IsEllipsis)
                {
                    <li class="page-item"><a class="page-link">...</a></li>
                }
                else
                {
                    <li class="page-item ">
                        <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">@p.Page</a>
                    </li>
                }
            }
        </ul>
    </div>
</div>