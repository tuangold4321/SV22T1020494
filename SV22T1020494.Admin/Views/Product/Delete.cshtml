@model SV22T1020494.Models.Catalog.Product
@{
    ViewBag.Title = "Xóa mặt hàng";
}

@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger">
        <i class="bi bi-trash me-1"></i>
        Xóa
    </button>
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" method="post" action="~/Product/Delete">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ProductID" />

                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle me-2"></i>
                        Bạn có chắc chắn muốn xóa mặt hàng sau không?
                    </div>

                    <div class="row">
                        <div class="col-md-8">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Tên mặt hàng</dt>
                                <dd class="col-sm-8">@Model.ProductName</dd>

                                <dt class="col-sm-4">Loại hàng</dt>
                                <dd class="col-sm-8">@Model.CategoryID</dd>

                                <dt class="col-sm-4">Nhà cung cấp</dt>
                                <dd class="col-sm-8">@Model.SupplierID</dd>

                                <dt class="col-sm-4">Đơn vị tính</dt>
                                <dd class="col-sm-8">@Model.Unit</dd>

                                <dt class="col-sm-4">Giá bán</dt>
                                <dd class="col-sm-8">@String.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:N0}", Model.Price)</dd>

                                <dt class="col-sm-4">Trạng thái</dt>
                                <dd class="col-sm-8">
                                    @if (Model.IsSelling)
                                    {
                                        <span class="badge bg-success">Đang bán</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Đã ngưng làm việc</span>
                                    }
                                </dd>

                                <dt class="col-sm-4">Mô tả</dt>
                                <dd class="col-sm-8">@Model.ProductDescription</dd>
                            </dl>
                        </div>

                        <div class="col-md-4 text-end">
                            @{ var photoFile = string.IsNullOrWhiteSpace(Model.Photo) ? "nophoto.png" : Model.Photo; var photoSrc = Url.Content("~/images/products/" + photoFile); }
                            <img src="@photoSrc"
                                 class="img-fluid img-thumbnail"
                                 alt="Ảnh mặt hàng"
                                 style="max-height: 220px;" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
