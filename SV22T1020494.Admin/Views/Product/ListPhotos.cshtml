@model List<SV22T1020494.Models.Catalog.ProductPhoto>
@{
    Layout = null;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="photos" class="mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        @{ var pid = ViewBag.ProductID ?? 0; }
                        <a class="btn btn-sm btn-primary" href="~/Product/CreatePhoto/@pid">
                            <i class="bi bi-plus-circle me-1"></i>
                            Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px">Hiển thị</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var p in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        @{ var imgSrc = Url.Content("~/images/products/" + (string.IsNullOrWhiteSpace(p.Photo) ? "demo.png" : p.Photo)); }
                                        <img src="@imgSrc"
                                             class="img-thumbnail"
                                             style="max-height:80px;" />
                                    </td>
                                    <td>@p.Description</td>
                                    <td class="text-center">@p.DisplayOrder</td>
                                    <td class="text-center">
                                        @if (p.IsHidden)
                                        {
                                            <span class="badge bg-secondary">Ẩn</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Hiện</span>
                                        }
                                    </td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary" href="~/Product/EditPhoto/@ViewBag.ProductID?photoId=@p.PhotoID">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @{ var productIdForLink = ViewBag.ProductID ?? 0; }
                                        <a class="btn btn-sm btn-danger ms-1 open-modal" href="~/Product/DeletePhoto?id=@productIdForLink&photoId=@p.PhotoID">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center">Không có ảnh nào</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>