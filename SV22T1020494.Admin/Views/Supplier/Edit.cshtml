@model SV22T1020494.Models.SupplierViewModel
@using SV22T1020494.Admin
@{
    // Preload provinces so the tag helper receives a concrete collection
    var _provinces = await SelectListHelper.Provinces();
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Supplier" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline" style="border-radius:8px;">
            <div class="card-header bg-white">
                <h5 class="card-title mb-0">
                    <i class="bi bi-truck me-2"></i>
                    Thông tin nhà cung cấp
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="~/Supplier/Save">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="SupplierID" />

                    <div class="mb-3">
                        <label class="form-label">Tên nhà cung cấp</label>
                        <input asp-for="SupplierName" type="text" class="form-control rounded-3" placeholder="Nhập tên nhà cung cấp"
                               autofocus />
                        <span asp-validation-for="SupplierName" class="text-danger"></span>
                        <div class="form-text text-muted">Vui lòng nhập tên nhà cung cấp</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tên giao dịch</label>
                        <input asp-for="ContactName" type="text" class="form-control rounded-3" placeholder="Nhập tên giao dịch" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Điện thoại</label>
                            <input asp-for="Phone" type="tel" class="form-control rounded-3" placeholder="Nhập số điện thoại" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control rounded-3" placeholder="Nhập email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                            <div class="form-text text-muted">Vui lòng cho biết email của nhà cung cấp</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea asp-for="Address" class="form-control rounded-3" rows="4" placeholder="Nhập địa chỉ"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tỉnh / Thành</label>
                        <select class="form-select rounded-3" asp-for="City" asp-items="@(_provinces)">
                        </select>
                        <div class="form-text text-muted">Vui lòng chọn tỉnh/thành</div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
