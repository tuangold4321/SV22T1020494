@using System.Globalization
@{
    Layout = null;
    var vi = CultureInfo.GetCultureInfo("vi-VN");
}

<div class="modal-header">
    <strong class="modal-title">
        Cập nhật chi tiết đơn hàng
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-8">
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Mặt hàng
                    </label>
                    <div class="col-sm-8">
                        <input type="text"
                               class="form-control-plaintext fw-bold"
                               value="@Model?.ProductName"
                               readonly>
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Số lượng
                    </label>
                    <div class="col-sm-5">
                        <input type="number"
                               class="qty-input"
                               min="1"
                               value="@Model?.Quantity">
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Đơn giá
                    </label>
                    <div class="col-sm-5">
                        <input type="text"
                               class="form-control text-end money-input"
                               value="@(Model?.SalePrice.ToString("N0", vi))">
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-end">
                <img src="/images/products/@Model?.Photo"
                     alt="@Model?.ProductName"
                     class="img-thumbnail"
                     style="max-height:180px">
            </div>
        </div>
    </div>
</div>

<div class="modal-footer">
    <button type="button" class="btn btn-primary" onclick="(function(btn){ var productId = @(Model?.ProductID ?? 0); if(productId === 0){ alert('Mặt hàng không hợp lệ'); return; } var modalEl = btn.closest('.modal') || document.getElementById('dialogModal'); var qtyInput = modalEl ? modalEl.querySelector('.qty-input') : null; var moneyInput = modalEl ? modalEl.querySelector('.money-input') : null; var quantity = qtyInput ? parseInt(qtyInput.value) || 1 : 1; var priceRaw = moneyInput ? (moneyInput.value||'') : ''; // remove group separators (.) and convert decimal comma to dot
            var normalized = priceRaw.replace(/\./g, '').replace(/,/g, '.');
            var price = moneyInput ? parseFloat(normalized) || 0 : 0; if(quantity <= 0){ alert('Số lượng không hợp lệ'); return; } btn.disabled = true; var originalText = btn.innerHTML; btn.innerHTML = 'Đang lưu...'; var formData = new FormData(); formData.append('productId', productId); formData.append('quantity', quantity); formData.append('price', price); fetch('/Order/EditCartItem', { method: 'POST', body: formData }).then(function(res){ return res.json(); }).then(function(data){ if(data.code > 0){ window.location.reload(); } else { alert(data.message || 'Không thể cập nhật mặt hàng'); btn.disabled = false; btn.innerHTML = originalText; } }).catch(function(err){ alert('Lỗi kết nối: ' + (err && err.message ? err.message : err)); btn.disabled = false; btn.innerHTML = originalText; }); })(this)">
        Cập nhật
    </button>
    <button type="button"
            class="btn btn-secondary"
            data-bs-dismiss="modal">
        Đóng
    </button>
</div>