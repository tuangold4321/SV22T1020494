@model SV22T1020494.Models.Common.PagedResult<SV22T1020494.Models.Sales.OrderViewInfo>
@using Microsoft.AspNetCore.WebUtilities
@using System.Linq
@{
    Layout = null;
}
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model?.RowCount</strong> đơn hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.DataItems != null && Model.DataItems.Any())
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td>@item.OrderTime.ToString("dd/MM/yyyy")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.CustomerName) ? (item.CustomerID?.ToString() ?? "") : item.CustomerName)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.CustomerPhone) ? "" : item.CustomerPhone)</td>
                            <td>@(item.AcceptTime.HasValue ? item.AcceptTime.Value.ToString("dd/MM/yyyy") : "")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.EmployeeName) ? (item.EmployeeID?.ToString() ?? "") : item.EmployeeName)</td>
                            <td class="text-end">@item.TotalAmount.ToString("N0")</td>
                            <td class="text-center">
                                @{

                                    var status = item.Status;
                                    string badgeClass = "badge bg-secondary";
                                    string statusText = status.GetDescription();

                                    switch (status)
                                    {
                                        case SV22T1020494.Models.Sales.OrderStatusEnum.New:
                                            badgeClass = "badge bg-warning text-dark";
                                            statusText = "Chờ duyệt";
                                            break;
                                        case SV22T1020494.Models.Sales.OrderStatusEnum.Accepted:
                                            badgeClass = "badge bg-info text-dark";
                                            statusText = "Đã duyệt";
                                            break;
                                        case SV22T1020494.Models.Sales.OrderStatusEnum.Shipping:
                                            badgeClass = "badge bg-primary";
                                            statusText = "Đang giao";
                                            break;
                                        case SV22T1020494.Models.Sales.OrderStatusEnum.Completed:
                                            badgeClass = "badge bg-success";
                                            statusText = "Hoàn tất";
                                            break;
                                        case SV22T1020494.Models.Sales.OrderStatusEnum.Cancelled:
                                            badgeClass = "badge bg-danger";
                                            statusText = "Bị hủy";
                                            break;
                                        case SV22T1020494.Models.Sales.OrderStatusEnum.Rejected:
                                            badgeClass = "badge bg-dark";
                                            statusText = "Bị từ chối";
                                            break;
                                    }
                                }
                                <span class="@badgeClass">@statusText</span>
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-receipt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">Không có đơn hàng</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model?.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                @{
                    int total = Model.PageCount;
                    int current = Model.Page;
                    int start = 1, end = total;

                    if (total <= 13)
                    {
                        start = 1;
                        end = total;
                    }
                    else if (current <= 7)
                    {
                        start = 1;
                        end = 11;
                    }
                    else if (current > total - 7)
                    {
                        start = total - 10;
                        end = total;
                    }
                    else
                    {
                        start = current - 5;
                        end = current + 5;
                    }

                    // helper to build url preserving current query params and setting page
                    Func<int, string> pageUrl = (p) => {
                        var req = ViewContext.HttpContext.Request;
                        var qs = req.Query.ToDictionary(k => k.Key, v => v.Value.ToString());
                        qs["page"] = p.ToString();
                        var basePath = Url.Action("Index", "Order") ?? "/Order/Index";
                        return QueryHelpers.AddQueryString(basePath, qs);
                    };

                    // render leading first page and ellipsis if needed
                    if (start > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@pageUrl(1)">1</a>
                        </li>
                        if (start > 2)
                        {
                            <li class="page-item"><span class="page-link">...</span></li>
                        }
                    }

                    for (int p = start; p <= end; p++)
                    {
                        if (p == current)
                        {
                            <li class="page-item active"><span class="page-link">@p</span></li>
                        }
                        else
                        {
                            <li class="page-item"><a class="page-link" href="@pageUrl(p)">@p</a></li>
                        }
                    }

                    // render trailing ellipsis and last page if needed
                    if (end < total)
                    {
                        if (end < total - 1)
                        {
                            <li class="page-item"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="@pageUrl(total)">@total</a>
                        </li>
                    }
                }
            </ul>
        </div>
    }
</div>
